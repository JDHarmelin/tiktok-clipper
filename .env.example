# ============================================================
# .env -- All credentials for the TikTok Clipper Agent
# ============================================================

# --- TELEGRAM BOT ---
# Get from: @BotFather on Telegram -> /newbot -> copy token
TELEGRAM_BOT_TOKEN=7123456789:AAF1234abcd5678efgh-XXXXXXXXXXX

# Your Telegram user ID (for restricting bot access to only you)
# Get from: @userinfobot on Telegram -> send /start -> copy your ID
ALLOWED_USER_ID=123456789

# --- ANTHROPIC (Claude API) ---
# Get from: https://console.anthropic.com/settings/keys -> Create Key
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- TIKTOK ---
# Export cookies from browser while logged into TikTok
# Use browser extension "Get cookies.txt LOCALLY" -> export -> save as cookies.txt
TIKTOK_COOKIES_PATH=./cookies.txt

# --- PIPELINE CONFIG ---
WHISPER_MODEL=medium           # tiny, base, small, medium, large-v3
WHISPER_DEVICE=cpu             # cpu or cuda (use "cpu" on Mac -- MLX handles acceleration)
WHISPER_COMPUTE_TYPE=int8      # int8 (CPU), float16 (GPU)
MAX_CLIPS_PER_VIDEO=10         # Max clips to generate per video
MIN_CLIP_DURATION=20           # Minimum clip length in seconds
MAX_CLIP_DURATION=90           # Maximum clip length in seconds
OUTPUT_WIDTH=1080              # Vertical video width
OUTPUT_HEIGHT=1920             # Vertical video height
DOWNLOAD_DIR=./downloads
CLIPS_DIR=./clips
SUBTITLES_DIR=./subtitles
